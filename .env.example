APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use https:// in production (e.g. Railway) so URLs and forms match the public URL.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# For MariaDB/MySQL instead of SQLite, set DB_CONNECTION=mysql and uncomment:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=akeira_snackinn
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
#
# If you see "Host 'localhost' is not allowed" (SQLSTATE 1130), the DB user must be
# granted for the same host as DB_HOST (localhost vs 127.0.0.1 differ). See README.

# Use `file` for local dev without extra DB tables. `database` requires migrations (sessions / cache / jobs tables).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional: admin user created by php artisan db:seed (AdminUserSeeder)
# Login uses Username = SEED_ADMIN_NAME and your password (not email, unless you set name = email).
# On Railway: set these in Variables, then run db:seed once (see README or deploy docs).
SEED_ADMIN_NAME=admin
SEED_ADMIN_EMAIL=admin@akeira.local
# SEED_ADMIN_PASSWORD=your-secure-password
# In production, SEED_ADMIN_PASSWORD is required when running the seeder.

# One-time URL: https://YOUR_DOMAIN/setup-first-admin?token=THIS_VALUE
# Generate a long random string; leave empty to disable (404). Rotate/remove after first use.
# SETUP_ADMIN_TOKEN=

# Optional: force new registrations into this shops.id so every user shares one Snack Inn (same products & orders).
# After migrate, check `shops` table for the id (usually 1). Staff can also join via Team code on Register.
# SNACK_INN_DEFAULT_SHOP_ID=1
